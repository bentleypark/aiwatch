{
  "name": "aiwatch",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "npm run build && wrangler dev",
    "test": "npx playwright test",
    "test:worker": "npx vitest run --config worker/vitest.config.ts",
    "test:ui": "npx playwright test --ui",
    "deploy": "npm run build && wrangler deploy",
    "deploy:worker": "npx wrangler deploy --config worker/wrangler.toml",
    "dev:worker": "npx wrangler dev --config worker/wrangler.toml --port 8788",
    "dev:all": "npx wrangler dev --config worker/wrangler.toml --port 8788 & vite"
  },
  "dependencies": {
    "chart.js": "^4.4.7",
    "react": "^19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.0",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.5",
    "wrangler": "^4.76.0"
  }
}
